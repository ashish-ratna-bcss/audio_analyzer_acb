# Copy to .env and fill in. .env is gitignored.

# Auth: clients must send  X-API-Key: <this value>
# Use a long random string, e.g.  openssl rand -hex 32
API_KEY=change-me-to-a-long-random-string

# HuggingFace token (required for pyannote diarization).
# Get at https://huggingface.co/settings/tokens and accept the license at
# https://huggingface.co/pyannote/speaker-diarization-3.1
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx

# Optional overrides (auto-detected if unset):
# DEVICE=cuda                 # or cpu
# WHISPER_COMPUTE_TYPE=float16  # or int8 for cpu

# --- Phase 1 async stack (compose sets these; override for external services) ---
# DATABASE_URL=postgresql+psycopg2://pipeline:pipeline@postgres:5432/forensic
# REDIS_URL=redis://redis:6379/0
# CASE_STORE_PATH=/data/forensic-audio
